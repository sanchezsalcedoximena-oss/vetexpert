generator client {
provider = "prisma-client-js"
}

datasource db {
provider = "postgresql"
url      = env("DATABASE_URL")
}

enum RolUsuario {
ADMIN
SECRETARIA
VETERINARIO
CLIENTE
}

model Usuario {
id        String      @id @default(cuid())
nombres   String
apellidos String
correo    String      @unique
password  String
rol        RolUsuario

createdAt DateTime    @default(now())
updatedAt DateTime    @updatedAt
}
